# Copy to .env and fill in real values. Never commit .env.
# Spring Boot does not read .env natively — export these into your shell
# (or use your IDE run-config / a dotenv plugin) before `./mvnw spring-boot:run`.

# --- Database (required) ---
MYSQL_USER=root
MYSQL_PASSWORD=changeme

# --- JWT (required) ---
# HS256 signing key, must be at least 32 characters
JWT_SECRET=change-me-to-a-random-string-of-32-plus-characters

# --- Stripe (required) ---
STRIPE_SECRET_KEY=your_stripe_test_secret_key_here
STRIPE_WEBHOOK_SECRET_KEY=your_stripe_webhook_secret_here

# --- Sentry (optional — leave unset/empty to disable the SDK) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
